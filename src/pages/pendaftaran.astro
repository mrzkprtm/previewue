            max-width: 50px;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .progress-circle {
            width: 28px;
            height: 28px;
            font-size: 11px;
        }
    }

    /* ── Focus-visible outlines for accessibility ──────────────────────────── */
    a:focus-visible,
    input:focus-visible,
    select:focus-visible,
    textarea:focus-visible,
    button:focus-visible {
        outline: 2px solid #145da0;
        outline-offset: 2px;

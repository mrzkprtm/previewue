---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomePaths from "../components/home/HomePaths.astro";
import HomePromos from "../components/home/HomePromos.astro";
import Mentors from "../components/home/old/Mentors.astro";
import Alumni from "../components/home/old/Alumni.astro";
import HighlightedArticles from "../components/home/old/HighlightedArticles.astro";
import FAQ from "../components/home/old/FAQ.astro";
import WhyChooseUs from "../components/home/WhyChooseUs.astro";
import FinalCTA from "@/components/home/FinalCTA.astro";
import ScholarshipPopup from "@/components/common/ScholarshipPopup.astro";
import LocationSection from "@/components/home/LocationSection.astro";
import SEOContent from "@/components/home/SEOContent.astro";
import HomePlacementTest from "../components/home/HomePlacementTest.astro";
import HomeSuccessCTA from "@/components/home/HomeSuccessCTA.astro";
import Scholarships from "../components/home/old/Scholarships.astro";
const title = "Ultimate Education - Konsultan Pendidikan Luar Negeri & Persiapan Tes";
const description = "Pusat bimbingan persiapan beasiswa, IELTS, SAT, GMAT, GRE, dan bahasa asing terpercaya di Jakarta & Bandung.";
---

<Layout title={title} description={description}>
  <!-- 1. Hero (Optimized) -->
  <HomeHero />

  <!-- 2. Services Overview (Refined) -->
  <HomePaths />

  <!-- 3. Program Highlights -->
  <HomePromos />

  <!-- 4. Placement Test (Restored) -->
  <HomePlacementTest />

  <!-- 5. Success CTA (Restored) -->
  <HomeSuccessCTA />

  <!-- 7. Why Choose Us -->
  <WhyChooseUs />

  <!-- 8. Student Success Stories -->
  <Alumni />

  <!-- 9. Mentors (Trust) -->
  <Mentors />

  <!-- 10. Scholarships Feed (Restored) -->
  <Scholarships />

  <!-- 11. Blog / Resources -->
  <HighlightedArticles />

  <!-- 12. SEO Content (Long Form) -->
  <SEOContent />

  <!-- 14. FAQ -->
  <FAQ />

  <!-- Popup -->
  <ScholarshipPopup />
</Layout>

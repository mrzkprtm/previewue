---
import Layout from "../../layouts/Layout.astro";
const title = "SAT Calculator - Ultimate Education";
const description = "Hitung estimasi skor Digital SAT dengan kalkulator interaktif.";
---

<Layout title={title} description={description}>
  <main class="bg-slate-50 min-h-screen">
    <section class="bg-hero-gradient">
      <div class="container mx-auto px-4 md:px-6 xl:px-0 py-12 lg:py-16">
        <div class="max-w-3xl text-white">
          <div class="inline-flex items-center rounded-full bg-white/10 border border-white/20 px-4 py-1.5 text-xs md:text-sm font-semibold text-ultimate-yellow mb-4">
            Kalkulator Skor
          </div>
          <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight mb-4">SAT Calculator</h1>
          <p class="text-white/80 text-base md:text-lg">Gunakan kalkulator Digital SAT yang responsif dan mudah digunakan.</p>
        </div>
      </div>
    </section>

    <section class="container mx-auto px-4 md:px-6 xl:px-0 py-10 lg:py-14">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-card p-4 md:p-6 lg:p-8">
        <div class="flex items-center justify-between flex-wrap gap-3 mb-4">
          <div>
            <h2 class="font-heading text-xl lg:text-2xl font-semibold text-slate-900">Digital SAT Score Calculator</h2>
            <p class="text-sm md:text-base text-slate-500">Masukkan skor English dan Math untuk melihat total.</p>
          </div>
          <a href="/embed/digital-sat-score-calculator" class="text-sm font-semibold text-ultimate-blue hover:underline">Buka versi penuh</a>
        </div>
        <div class="w-full overflow-hidden rounded-xl border border-slate-200 bg-slate-50">
          <iframe
            src="/embed/digital-sat-score-calculator"
            class="w-full min-h-[900px] lg:min-h-[820px]"
            frameborder="0"
            referrerpolicy="strict-origin-when-cross-origin"
            title="Digital SAT Score Calculator"
          ></iframe>
        </div>
      </div>
    </section>
  </main>
</Layout>

---

---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <title>IELTS Test Instructions Page - Ultimate Education</title>
        <link href="https://fonts.googleapis.com" rel="preconnect" />
        <link
            crossorigin=""
            href="https://fonts.gstatic.com"
            rel="preconnect"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@600;700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
        <style>
            .bg-gradient-blue {
                background: linear-gradient(
                    160deg,
                    #145da0 0%,
                    #042f56 100%
                ); /* Ultimate Education Navy/Blue theme */
            }
            .curved-overlay {
                background: rgba(255, 255, 255, 0.05);
                border-radius: 50%;
                position: absolute;
            }
        </style>
    </head>
    <body
        class="bg-slate-50 font-sans text-gray-800 min-h-screen flex flex-col transition-colors duration-300"
    >
        <header
            class="w-full bg-white border-b border-gray-200 py-4 px-6 md:px-12 flex justify-between items-center sticky top-0 z-50 shadow-sm"
        >
            <div class="flex items-center gap-2">
                <a href="/">
                    <img
                        src="/logos/logo-ue.png"
                        alt="Ultimate Education"
                        class="h-10 w-auto"
                    />
                </a>
            </div>
            <a
                class="group flex items-center gap-2 px-5 py-2 border border-gray-300 rounded-full text-sm font-medium text-gray-600 hover:border-ultimate-blue hover:text-ultimate-blue transition-all duration-200"
                href="/placement-test"
            >
                <span
                    class="material-symbols-outlined text-base transition-transform group-hover:-translate-x-1"
                    >chevron_left</span
                >
                BACK TO WEBSITE
            </a>
        </header>
        <main class="flex-grow flex items-center justify-center p-6 md:p-12">
            <div
                class="w-full max-w-5xl bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col md:flex-row min-h-[500px]"
            >
                <div
                    class="relative w-full md:w-5/12 bg-gradient-blue p-8 flex flex-col justify-end overflow-hidden"
                >
                    <div
                        class="curved-overlay w-[400px] h-[400px] -bottom-20 -left-20"
                    >
                    </div>
                    <div
                        class="curved-overlay w-[300px] h-[300px] bottom-20 -right-10"
                    >
                    </div>
                    <div
                        class="absolute top-8 -right-8 w-48 rotate-12 drop-shadow-xl z-20"
                    >
                        <div
                            class="bg-[#145da0] h-32 w-48 relative transform rotate-12 rounded-lg shadow-lg flex items-center justify-center overflow-hidden border-2 border-white/20"
                        >
                            <div class="absolute inset-0 bg-[#00247d]">
                                <div
                                    class="absolute inset-0 flex items-center justify-center"
                                >
                                    <div
                                        class="w-full h-4 bg-white transform rotate-45 opacity-50"
                                    >
                                    </div>
                                    <div
                                        class="w-full h-4 bg-white transform -rotate-45 opacity-50"
                                    >
                                    </div>
                                    <div class="w-full h-8 bg-white opacity-50">
                                    </div>
                                    <div class="h-full w-8 bg-white opacity-50">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="relative z-10 text-white mt-32 md:mt-0">
                        <div class="flex items-center mb-2">
                            <span
                                class="font-display font-bold text-3xl tracking-tight mr-2"
                                >Ultimate Education</span
                            >
                        </div>
                        <div class="flex items-center gap-2">
                            <span
                                class="material-symbols-outlined text-xl opacity-90"
                                >menu_book</span
                            >
                            <h2
                                class="font-display font-bold text-2xl tracking-wide"
                            >
                                IELTS Preparation
                            </h2>
                        </div>
                    </div>
                </div>
                <div class="w-full md:w-7/12 p-8 md:p-12 flex flex-col">
                    <div
                        class="bg-ultimate-navy rounded-lg p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center text-white mb-8 shadow-md gap-4 sm:gap-0"
                    >
                        <div class="flex items-center gap-3 w-full sm:w-auto">
                            <div class="bg-white/10 p-2 rounded-md">
                                <span class="material-symbols-outlined text-xl"
                                    >assignment</span
                                >
                            </div>
                            <div class="flex flex-col">
                                <span class="text-xs text-blue-100 font-medium"
                                    >Jumlah Soal</span
                                >
                                <span class="font-bold text-lg text-yellow-400"
                                    >25</span
                                >
                            </div>
                        </div>
                        <div class="hidden sm:block w-px h-8 bg-white/20 mx-4">
                        </div>
                        <div class="flex items-center gap-3 w-full sm:w-auto">
                            <div class="bg-white/10 p-2 rounded-md">
                                <span class="material-symbols-outlined text-xl"
                                    >schedule</span
                                >
                            </div>
                            <div class="flex flex-col">
                                <span class="text-xs text-blue-100 font-medium"
                                    >Waktu Pengerjaan</span
                                >
                                <span class="font-bold text-lg text-yellow-400"
                                    >∞</span
                                >
                            </div>
                        </div>
                    </div>
                    <div class="flex-grow">
                        <h3
                            class="font-display font-bold text-xl text-ultimate-navy mb-6"
                        >
                            Instruksi Placement Test
                        </h3>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <!-- Card 1 -->
                            <div
                                class="bg-slate-50 rounded-xl overflow-hidden border border-slate-100 flex flex-col"
                            >
                                <div class="h-24 bg-slate-200 overflow-hidden">
                                    <img
                                        src="/steps/instr1.png"
                                        alt="Instruksi 1"
                                        class="w-full h-full object-fill"
                                    />
                                </div>
                                <div class="p-3">
                                    <p
                                        class="text-xs text-slate-700 leading-relaxed"
                                    >
                                        <span
                                            class="font-bold text-ultimate-blue"
                                            >10 Soal Listening, 8 Grammar, 7
                                            Reading.</span
                                        >
                                    </p>
                                </div>
                            </div>

                            <!-- Card 2 -->
                            <div
                                class="bg-slate-50 rounded-xl overflow-hidden border border-slate-100 flex flex-col"
                            >
                                <div class="h-24 bg-slate-200 overflow-hidden">
                                    <img
                                        src="/steps/instr2.png"
                                        alt="Instruksi 2"
                                        class="w-full h-full object-fill"
                                    />
                                </div>
                                <div class="p-3">
                                    <p
                                        class="text-xs text-slate-700 leading-relaxed"
                                    >
                                        Perhatikan detail soal dan jawaban yang
                                        sudah dipilih.
                                    </p>
                                </div>
                            </div>

                            <!-- Card 3 -->
                            <div
                                class="bg-slate-50 rounded-xl overflow-hidden border border-slate-100 flex flex-col"
                            >
                                <div class="h-24 bg-slate-200 overflow-hidden">
                                    <img
                                        src="/steps/instr3.png"
                                        alt="Instruksi 3"
                                        class="w-full h-full object-fill"
                                    />
                                </div>
                                <div class="p-3">
                                    <p
                                        class="text-xs text-slate-700 leading-relaxed"
                                    >
                                        Pastikan seluruh jawaban terisi sebelum
                                        klik submit.
                                    </p>
                                </div>
                            </div>

                            <!-- Card 4 -->
                            <div
                                class="bg-slate-50 rounded-xl overflow-hidden border border-slate-100 flex flex-col"
                            >
                                <div class="h-24 bg-slate-200 overflow-hidden">
                                    <img
                                        src="/steps/instr4.png"
                                        alt="Instruksi 4"
                                        class="w-full h-full object-fill"
                                    />
                                </div>
                                <div class="p-3">
                                    <p
                                        class="text-xs text-slate-700 leading-relaxed"
                                    >
                                        Placement test hanya bisa dilakukan satu
                                        kali per akun.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-8 flex justify-end">
                        <a
                            href="/placement-test/ielts-free-test"
                            class="bg-ultimate-yellow hover:brightness-110 text-ultimate-navy font-extrabold py-4 px-10 rounded-xl shadow-xl shadow-yellow-500/20 transform transition hover:-translate-y-1 active:scale-95 focus:outline-none flex items-center gap-2"
                        >
                            MULAI TES
                            <span class="material-symbols-outlined text-lg"
                                >play_arrow</span
                            >
                        </a>
                    </div>
                </div>
            </div>
        </main>
        <footer
            class="w-full bg-gradient-to-r from-ultimate-navy to-ultimate-blue text-white text-center py-8 text-sm"
        >
            <div class="container mx-auto px-4">
                <p class="opacity-70">
                    © 2026 Ultimate Education. All rights reserved.
                </p>
            </div>
        </footer>
    </body>
</html>

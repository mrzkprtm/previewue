        </div>

        <script is:inline define:vars={{ testData, totalQuestions }}>
            // Security Guard & Stage Management [NEW]
            const urlParams = new URLSearchParams(window.location.search);
            const registrationId =
                urlParams.get("registrationId") ||
                sessionStorage.getItem("placement_registration_id");
            const stage = sessionStorage.getItem("placement_stage");

            if (
                !registrationId ||
                !stage ||
                (stage !== "instruction" && stage !== "testing")
            ) {
                alert(
                    "Sesi tidak valid atau telah berakhir. Silakan mendaftar kembali.",
                );
                window.location.href = "/placement-test";
            }

            // Handle Instruction UI
            const instructionOverlay = document.getElementById(
                "instruction-overlay",
            );
            const pahamBtn = document.getElementById("paham-btn");

            if (stage === "testing") {
                instructionOverlay?.classList.add("hidden");
            }

            pahamBtn.onclick = () => {
                sessionStorage.setItem("placement_stage", "testing");
                instructionOverlay?.classList.add("hidden");
                render(); // Initial render after starting
            };

            // State management
            let currentTypeIndex = 0; // verbal, math
            let currentSectionIndex = 0; // within current type
            let currentQuestionIndex = 0; // within current section
            const typesOrder = ["verbal", "math"];
            const userAnswers = {}; // map of global_question_id -> selected_value

            function processMathMarkup(html) {
                if (!html) return "";
                const temp = document.createElement("div");
                temp.innerHTML = html;

                // Find all Quill formula spans
                const formulas = temp.querySelectorAll(".ql-formula");
                formulas.forEach((span) => {
                    const latex = span.getAttribute("data-value");
                    if (latex) {
                        // Create a math-field-like element for MathLive to pick up
                        const mathEl = document.createElement("math-field");
                        mathEl.setAttribute("read-only", "true");
                        mathEl.textContent = latex.trim();
                        span.parentNode.replaceChild(mathEl, span);
                    }
                });

                return temp.innerHTML;
            }

            // Elements
            const elements = {
                sectionIcon: document.getElementById("section-icon"),
                currentSectionDisplay: document.getElementById(
                    "current-section-display",
                ),
                sectionDetailText: document.getElementById(
                    "section-detail-text",
                ),
                answeredCount: document.getElementById("answered-count"),
                progressBar: document.getElementById("progress-bar"),
                progressText: document.getElementById("progress-text"),
                progressCircle: document.getElementById("progress-circle"),
                sectionTabs: document.getElementById("section-tabs"),
                subSectionsNav: document.getElementById("sub-sections-nav"),
                mediaContent: document.getElementById("media-content"),
                questionsContainer: document.getElementById(
                    "questions-container",
                ),
                questionMapGrid: document.getElementById("question-map-grid"),
                verbalProgress: document.getElementById("verbal-progress"),
                mathProgress: document.getElementById("math-progress"),
                finishModal: document.getElementById("finish-modal"),
                closeTestBtn: document.getElementById("close-test-btn"),
            };

            const icons = {
                verbal: "menu_book",
                math: "calculate",
            };

            function initTabs() {
                elements.sectionTabs.innerHTML = typesOrder
                    .map(
                        (type, idx) => `
                    <button 
                        data-type-idx="${idx}"
                        class="flex-1 md:flex-none flex items-center justify-center gap-2 px-6 py-2 rounded-md transition-all text-sm font-semibold ${idx === currentTypeIndex ? "bg-ultimate-blue text-white shadow-sm" : "text-slate-600 hover:bg-gray-100"}"
                    >
                        <span class="material-symbols-outlined text-sm">${icons[type]}</span>
                        ${type.toUpperCase()}
                    </button>
                `,
                    )
                    .join("");

                elements.sectionTabs
                    .querySelectorAll("button")
                    .forEach((btn) => {
                        btn.onclick = () => {
                            currentTypeIndex = parseInt(btn.dataset.typeIdx);
                            currentSectionIndex = 0;
                            currentQuestionIndex = 0;
                            render();
                        };
                    });
            }

            function updateProgress() {
                const totalAnswered = Object.keys(userAnswers).length;
                const progressPct = Math.round(
                    (totalAnswered / totalQuestions) * 100,
                );

                elements.answeredCount.innerText = totalAnswered;
                elements.progressBar.style.width = `${progressPct}%`;
                elements.progressText.innerText = `${progressPct}% Complete`;
                elements.progressCircle.setAttribute(
                    "stroke-dasharray",
                    `${progressPct}, 100`,
                );

                // Type specific progress
                ["verbal", "math"].forEach((type) => {
                    const sections = testData.filter(
                        (d) => d.jenis_soal.toLowerCase() === type,
                    );
                    let answered = 0;
                    let total = 0;
                    sections.forEach((s) => {
                        total += s.questions.length;
                        s.questions.forEach((q, qIdx) => {
                            if (userAnswers[`${s.id}_${qIdx}`]) answered++;
                        });
                    });
                    document.getElementById(`${type}-progress`).innerText =
                        `${answered}/${total}`;
                });
            }

            function render() {
                const currentType = typesOrder[currentTypeIndex];
                const activeSections = testData.filter(
                    (d) => d.jenis_soal.toLowerCase() === currentType,
                );
                const currentData = activeSections[currentSectionIndex];

                if (!currentData) return;

                // Update UI state
                elements.sectionIcon.innerText = icons[currentType];
                elements.currentSectionDisplay.innerText = `${currentType} section`;
                elements.sectionDetailText.innerText = `${currentType} - section ${currentData.section}`;

                // Update type tabs
                initTabs();

                // Render mini-tabs for sub-sections (section 1, 2, 3...)
                elements.subSectionsNav.innerHTML = activeSections
                    .map(
                        (s, idx) => `
                    <button 
                        class="px-4 py-1.5 text-[10px] font-bold uppercase rounded-full shadow-sm transition-all ${idx === currentSectionIndex ? "bg-ultimate-navy text-white" : "bg-gray-100 text-slate-400 hover:bg-gray-200"}"
                        onclick="window.changeSection(${idx})"
                    >
                        Section ${s.section}
                    </button>
                `,
                    )
                    .join("");

                // Render Media / Text Panel
                if (currentType === "verbal" && currentData.media_url_global) {
                    elements.mediaContent.innerHTML = `
                        <p class="text-sm italic text-slate-500 mb-8 border-l-4 border-ultimate-blue pl-4">
                            Listen to the audio and answer the questions that follow.
                        </p>
                        <div class="w-full bg-white rounded-xl p-5 border border-gray-100 mb-6 shadow-sm">
                            <audio controls class="w-full h-10 custom-audio-player">
                                <source src="${currentData.media_url_global}" type="audio/mpeg">
                                Your browser does not support the audio element.
                            </audio>
                        </div>
                    `;
                } else if (currentData.global_text) {
                    elements.mediaContent.innerHTML = `
                        <div class="prose prose-slate max-w-none text-sm leading-relaxed text-slate-600 bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                            ${processMathMarkup(currentData.global_text)}
                        </div>
                    `;
                } else {
                    elements.mediaContent.innerHTML = `<div class="p-8 text-center text-slate-400 italic">No instructions needed for this section.</div>`;
                }

                // Render Questions
                const q = currentData.questions[currentQuestionIndex];
                const idx = currentQuestionIndex;
                const qId = `${currentData.id}_${idx}`;
                const currentAns = userAnswers[qId];

                const isFirstOverall =
                    currentTypeIndex === 0 &&
                    currentSectionIndex === 0 &&
                    currentQuestionIndex === 0;
                const isLastOverall =
                    currentTypeIndex === typesOrder.length - 1 &&
                    currentSectionIndex === activeSections.length - 1 &&
                    currentQuestionIndex === currentData.questions.length - 1;

                elements.questionsContainer.innerHTML = `
                    <div class="p-4 rounded-xl border border-transparent hover:border-slate-100 transition-all">
                        <h3 class="font-bold text-slate-900 flex gap-3 mb-4">
                            <span class="w-6 h-6 rounded-full bg-slate-100 text-slate-500 text-[11px] flex items-center justify-center font-bold">${idx + 1}</span>
                            <div class="question-text">${processMathMarkup(q.soal)}</div>
                        </h3>
                        <div class="space-y-3 pl-9">
                            ${[
                                "pilihan_a",
                                "pilihan_b",
                                "pilihan_c",
                                "pilihan_d",
                            ]
                                .map((optKey) => {
                                    const optVal = q[optKey];
                                    if (!optVal) return "";
                                    const optLetter = optKey
                                        .split("_")[1]
                                        .toUpperCase();
                                    return `
                                    <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 hover:bg-slate-50 cursor-pointer transition-all ${currentAns === optLetter ? "bg-blue-50 border-blue-200" : ""}">
                                        <input 
                                            type="radio" 
                                            name="${qId}" 
                                            value="${optLetter}" 
                                            ${currentAns === optLetter ? "checked" : ""}
                                            class="text-ultimate-blue focus:ring-ultimate-blue w-5 h-5 border-gray-300"
                                            onchange="window.saveAnswer('${currentData.id}', ${idx}, '${optLetter}')"
                                        >
                                        <span class="text-sm font-medium text-slate-700 option-text">${processMathMarkup(optVal)}</span>
                                    </label>
                                `;
                                })
                                .join("")}
                        </div>
                    </div>
                    <div class="flex justify-between mt-8 border-t border-gray-100 pt-6">
                        <button onclick="window.prevQuestion()" class="${isFirstOverall ? "invisible" : ""} px-6 py-2 rounded-xl border border-gray-200 text-slate-600 font-bold hover:bg-gray-50 flex items-center gap-2 transition-all">
                            <span class="material-symbols-outlined text-sm">arrow_back</span> Back
                        </button>
                        <button onclick="window.nextQuestion()" class="px-8 py-2.5 rounded-xl bg-ultimate-navy text-white font-bold hover:bg-slate-800 flex items-center gap-2 shadow-lg shadow-blue-900/20 transition-all">
                            ${isLastOverall ? "Finish Test" : 'Next <span class="material-symbols-outlined text-sm">arrow_forward</span>'}
                        </button>
                    </div>
                `;

                renderQuestionMap();
                updateProgress();
            }

            function renderQuestionMap() {
                elements.questionMapGrid.innerHTML =
                    typesOrder
                        .map((type) => {
                            const sections = testData.filter(
                                (d) => d.jenis_soal.toLowerCase() === type,
                            );
                            let qList = [];
                            sections.forEach((s, sIdx) => {
                                s.questions.forEach((q, qIdx) => {
                                    qList.push({
                                        sId: s.id,
                                        qIdx,
                                        label: qList.length + 1,
                                        type,
                                        sectionIdx: sIdx,
                                        typeIdx: typesOrder.indexOf(type),
                                    });
                                });
                            });

                            return `
                        <div>
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">
                                ${type}
                            </p>
                            <div class="flex flex-wrap gap-2">
                                ${qList
                                    .map((item) => {
                                        const isAnswered =
                                            !!userAnswers[
                                                `${item.sId}_${item.qIdx}`
                                            ];
                                        const isCurrent =
                                            item.typeIdx === currentTypeIndex &&
                                            item.sectionIdx ===
                                                currentSectionIndex &&
                                            item.qIdx === currentQuestionIndex;
                                        return `
                                        <div 
                                            class="w-9 h-9 rounded-lg border-2 text-xs font-bold flex items-center justify-center cursor-pointer transition-all ${isAnswered ? "bg-green-500 text-white border-green-500 shadow-sm" : "border-slate-100 text-slate-400 hover:bg-slate-50"} ${isCurrent ? "ring-2 ring-ultimate-blue ring-offset-2" : ""}"
                                            onclick="window.jumpToQuestion(${item.typeIdx}, ${item.sectionIdx}, ${item.qIdx})"
                                        >
                                            ${item.label}
                                        </div>
                                    `;
                                    })
                                    .join("")}
                            </div>
                        </div>
                    `;
                        })
                        .join("") +
                    `
                    <div class="bg-blue-50/50 p-6 rounded-2xl flex flex-col justify-between items-center text-center">
                        <div class="mb-4">
                            <p class="font-bold text-ultimate-navy text-sm mb-1">Ready to Finish?</p>
                            <p class="text-[11px] text-slate-500">Submit your final answers.</p>
                        </div>
                        <button 
                            id="submit-test-btn"
                            class="w-full bg-ultimate-yellow text-ultimate-navy py-3 px-6 rounded-xl font-extrabold text-xs tracking-widest uppercase shadow-xl shadow-yellow-200/50 hover:-translate-y-1 transition-all"
                        >
                            Submit Test
                        </button>
                    </div>
                `;

                const submitBtn = document.getElementById("submit-test-btn");
                if (submitBtn) {
                    submitBtn.onclick = () => {
                        const totalAnswered = Object.keys(userAnswers).length;
                        document.getElementById("answered-stat").innerText =
                            totalAnswered;
                        document.getElementById("total-stat").innerText =
                            totalQuestions;

                        const warning =
                            document.getElementById("unanswered-warning");
                        if (totalAnswered < totalQuestions) {
                            warning.classList.remove("hidden");
                            warning.classList.add(
                                "flex",
                                "items-start",
                                "gap-3",
                            );
                        } else {
                            warning.classList.add("hidden");
                            warning.classList.remove(
                                "flex",
                                "items-start",
                                "gap-3",
                            );
                        }

                        elements.finishModal.classList.remove("hidden");
                        elements.finishModal.classList.add("flex");
                    };
                }
            }

            // Expose globally for onclick handlers
            window.saveAnswer = (sId, qIdx, val) => {
                userAnswers[`${sId}_${qIdx}`] = val;
                render(); // Re-render to update highlights & progress
            };

            window.changeSection = (idx) => {
                currentSectionIndex = idx;
                currentQuestionIndex = 0;
                render();
            };

            window.jumpToQuestion = (typeIdx, sectionIdx, qIdx) => {
                currentTypeIndex = typeIdx;
                currentSectionIndex = sectionIdx;
                currentQuestionIndex = qIdx;
                render();
            };

            window.prevQuestion = () => {
                if (currentQuestionIndex > 0) {
                    currentQuestionIndex--;
                } else if (currentSectionIndex > 0) {
                    currentSectionIndex--;
                    const prevSection = testData.filter(
                        (d) =>
                            d.jenis_soal.toLowerCase() ===
                            typesOrder[currentTypeIndex],
                    )[currentSectionIndex];
                    currentQuestionIndex = prevSection.questions.length - 1;
                } else if (currentTypeIndex > 0) {
                    currentTypeIndex--;
                    const activeSections = testData.filter(
                        (d) =>
                            d.jenis_soal.toLowerCase() ===
                            typesOrder[currentTypeIndex],
                    );
                    currentSectionIndex = activeSections.length - 1;
                    const prevSection = activeSections[currentSectionIndex];
                    currentQuestionIndex = prevSection.questions.length - 1;
                }
                render();
            };

            window.nextQuestion = () => {
                const currentType = typesOrder[currentTypeIndex];
                const activeSections = testData.filter(
                    (d) => d.jenis_soal.toLowerCase() === currentType,
                );
                const currentData = activeSections[currentSectionIndex];

                if (currentQuestionIndex < currentData.questions.length - 1) {
                    currentQuestionIndex++;
                } else if (currentSectionIndex < activeSections.length - 1) {
                    currentSectionIndex++;
                    currentQuestionIndex = 0;
                } else if (currentTypeIndex < typesOrder.length - 1) {
                    currentTypeIndex++;
                    currentSectionIndex = 0;
                    currentQuestionIndex = 0;
                } else {
                    document.getElementById("submit-test-btn").click();
                    return;
                }
                render();
            };

            document.getElementById("back-to-test-btn").onclick = () => {
                elements.finishModal.classList.add("hidden");
                elements.finishModal.classList.remove("flex");
            };

            document.getElementById("confirm-submit-btn").onclick =
                async () => {
                    const btn = document.getElementById("confirm-submit-btn");
                    const originalText = btn.innerHTML;

                    try {
                        // Get registrationId from URL or session storage
                        // In a real flow, it would be passed from the instruction/registration page
                        const urlParams = new URLSearchParams(
                            window.location.search,
                        );
                        let registrationId = urlParams.get("registrationId");

                        if (!registrationId) {
                            // Fallback: check if we have it in session storage from the registration ritual
                            registrationId = sessionStorage.getItem(
                                "placement_registration_id",
                            );
                        }

                        if (!registrationId) {
                            alert(
                                "Registration ID not found. Please register first.",
                            );
                            window.location.href = "/placement-test";
                            return;
                        }

                        // Show loading state
                        btn.disabled = true;
                        btn.innerHTML = `<span class="loading loading-spinner loading-sm"></span> Analysing Results...`;

                        const response = await fetch("/api/submit-sat-test", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                            },
                            body: JSON.stringify({
                                registrationId,
                                answers: userAnswers,
                            }),
                        });

                        const result = await response.json();

                        if (response.ok) {
                            // Update stage to result
                            sessionStorage.setItem("placement_stage", "result");
                            sessionStorage.removeItem("ielts_test_results");
                            // Redirect to the score report with registrationId
                            window.location.href = `/placement-test/results/sat-score-report?registrationId=${registrationId}`;
                        } else {
                            throw new Error(
                                result.error || "Failed to submit test results",
                            );
                        }
                    } catch (error) {
                        console.error("Submission error:", error);
                        alert(
                            "Terjadi kesalahan saat memproses hasil tes. Silakan coba lagi.",
                        );
                        btn.disabled = false;
                        btn.innerHTML = originalText;
                    }
                };

            // Start
            render();
        </script>
    </body>
</html>

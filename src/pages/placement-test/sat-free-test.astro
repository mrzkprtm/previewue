---
export const prerender = false;

const SUPABASE_URL = import.meta.env.SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY;

// Fetch SAT questions from Supabase
let testData: any[] = [];
try {
    const res = await fetch(
        `${SUPABASE_URL}/rest/v1/cms_pretests?nama_program=eq.SAT&deleted_at=is.null&order=jenis_soal.asc,section.asc`,
        {
            headers: {
                apikey: SUPABASE_ANON_KEY,
                Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
            },
        },
    );
    if (res.ok) {
        testData = await res.json();
    }
} catch (error) {
    console.error("Error fetching SAT data:", error);
}

// Group data by type (verbal, math)
const verbalSections = testData.filter(
    (d) => d.jenis_soal.toLowerCase() === "verbal",
);
const mathSections = testData.filter(
    (d) => d.jenis_soal.toLowerCase() === "math",
);

const totalQuestions = testData.reduce(
    (acc, curr) => acc + (curr.questions?.length || 0),
    0,
);

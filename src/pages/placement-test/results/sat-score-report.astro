                    <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Oops! Data tidak ditemukan</h2>
                    <p class="text-slate-600 dark:text-slate-400 text-lg mb-8">{error}</p>
                    <a href="/" class="inline-flex items-center gap-2 bg-hero-gradient text-white px-8 py-4 rounded-full font-bold hover:shadow-lg transition-all transform hover:scale-105">
                        <span class="material-symbols-outlined">home</span>
                        Kembali ke Home
                    </a>
                </div>
            </main>
        )}

        {scoreData && (
        <main class="w-full flex-grow pb-20">
            <!-- Hero Section: Pure Gradient -->
            <div class="bg-hero-gradient text-white pt-12 pb-24 px-4 md:px-12 relative">
                <div class="container mx-auto max-w-6xl relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                    <div class="text-center md:text-left space-y-4 max-w-xl">
                        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-1.5 rounded-full text-sm font-medium border border-white/30">
                            <span class="material-symbols-outlined text-lg">celebration</span>

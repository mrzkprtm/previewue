                BACK TO WEBSITE
            </a>
        </header>

        {error && (
            <main class="w-full flex-grow flex items-center justify-center p-8">
                <div class="bg-white dark:bg-card-dark p-12 rounded-3xl shadow-2xl text-center max-w-2xl border border-red-100 dark:border-red-900/30">
                    <div class="w-20 h-20 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-4xl text-red-600">error</span>

                    </div>
                    
                    <!-- Overall Band: Full Circle Progress -->
                    <div class="flex flex-col items-center justify-center p-8 min-w-[320px]">
                        <div class="relative w-56 h-56">
                            <canvas id="gaugeOverall"></canvas>
                            <div class="absolute inset-0 flex flex-col items-center justify-center text-white">
                                <span class="text-6xl font-bold">{scoreData.overallBand}</span>
                                <span class="text-sm font-medium uppercase tracking-widest opacity-80 mt-1">Total Score</span>
                            </div>
                        </div>
                        <div class="mt-6 text-center">
                            <span class="text-sm font-medium text-blue-50 opacity-80 uppercase tracking-widest">Overall Estimated Score</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container mx-auto max-w-6xl px-4 md:px-6 -mt-16 relative z-20 space-y-12">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Section Cards -->
                    {Object.entries(scoreData.sections).map(([id, data]) => {
                        const incorrect = data.total - data.correct;
                        const correctWins = data.correct >= incorrect;
                        return (
                        <div class="bg-white rounded-2xl shadow-soft overflow-hidden flex flex-col h-full border border-gray-100">
                            <div class="p-6 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
                                <div class="flex items-center gap-3">
                                    <div class={`p-2 rounded-lg ${id === 'verbal' ? 'bg-blue-100 text-blue-600' : 'bg-purple-100 text-purple-600'}`}>
                                        <span class="material-symbols-outlined">{id === 'verbal' ? 'menu_book' : 'calculate'}</span>
                                    </div>
                                    <h3 class="font-bold text-lg text-slate-900 capitalize">
                                        {id}
                                    </h3>
                                </div>
                                <span class={`text-xs font-bold px-2 py-1 rounded ${id === 'verbal' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700'}`}>
                                    {data.level}
                                </span>
                            </div>
                            <div class="p-6 flex flex-col flex-grow bg-white">
                                <div class="flex flex-col items-center mb-6">
                                    <div class="relative w-48 h-32">
                                        <canvas id={`gauge${id.charAt(0).toUpperCase() + id.slice(1)}`}></canvas>
                                        <div class="absolute inset-0 flex items-end justify-center pb-2">
                                            <span class="text-3xl font-bold text-slate-900">{data.band}</span>
                                        </div>
                                    </div>
                                    <span class="text-xs text-slate-500 mt-2 font-medium">Score (Max 800)</span>
                                </div>
                                
                                <!-- Correct/Incorrect Comparison Bar -->
                                <div class="mb-8">
                                    <div class="flex justify-between text-xs mb-2 font-bold uppercase tracking-tight">
                                        <div class="flex items-center gap-1.5 p-1 px-2 rounded-md bg-emerald-50 text-emerald-700">
                                            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                            Correct: {data.correct}
                                        </div>
                                        <div class={`flex items-center gap-1.5 p-1 px-2 rounded-md ${!correctWins ? 'bg-rose-100 text-rose-700' : 'bg-rose-50 text-rose-500'}`}>
                                            <span class="w-2 h-2 rounded-full bg-rose-500"></span>
                                            Incorrect: {incorrect}
                                        </div>
                                    </div>
                                    <div class="h-5 bg-gray-100 rounded-full flex overflow-hidden shadow-inner relative group">
                                        <div 
                                            class="h-full bg-emerald-500 transition-all duration-1000 ease-out relative z-10" 
                                            style={`width: ${data.total > 0 ? (data.correct / data.total) * 100 : 0}%`}
                                        ></div>
                                        <div 
                                            class="h-full bg-rose-400 transition-all duration-1000 ease-out relative z-10" 
                                            style={`width: ${data.total > 0 ? (incorrect / data.total) * 100 : 100}%`}
                                        ></div>
                                    </div>
                                </div>

                                <div class="space-y-4 text-sm flex-grow">
                                    <div>
                                        <h4 class="font-semibold text-slate-800 mb-2 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-green-500 text-base">check_circle</span> Strengths

---
export const prerender = false;

// Fetch registration_id from URL
const { searchParams } = Astro.url;
const registrationId = searchParams.get('registrationId');

let scoreData = null;
let error = null;

if (!registrationId) {
    error = "Registration ID is required to view results.";
} else {
    try {
        const SUPABASE_URL = import.meta.env.SUPABASE_URL;
        const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY;

        // Fetch result with join to get student name
        const response = await fetch(
            `${SUPABASE_URL}/rest/v1/placement_test_results?registration_id=eq.${registrationId}&select=*,placement_test_registrations(name)`,
            {
                method: "GET",
                headers: {
                    apikey: SUPABASE_ANON_KEY,
                    Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
                    "Content-Type": "application/json",
                },
            }
        );

        if (!response.ok) {
            throw new Error(`Failed to fetch: ${response.statusText}`);
        }

        const data = await response.json();
        
        if (!data || data.length === 0) {
            error = "Result not found for this registration.";
        } else {
            const raw = data[0];
            
            const getLevel = (score: number) => {
                if (score >= 700) return "Excellent";
                if (score >= 600) return "Good";
                if (score >= 500) return "Medium";
                return "Beginner";
            };

            // Safety net: if section was attempted but stored band is 0 (old record),
            // display the IELTS minimum of 1.0 instead.
            const normalizeBand = (band: number, total: number): number => {
                const b = parseFloat(String(band));
                if (total > 0 && b === 0) return 1.0;
                return b;
            };

            const verbalBand = normalizeBand(raw.listening_band, raw.listening_total);
            const mathBand   = normalizeBand(raw.grammar_band,   raw.grammar_total);
            const overallBand = verbalBand + mathBand;

            scoreData = {
                name: raw.placement_test_registrations?.name || "Student",
                overallBand,
                aiSummary: raw.ai_analysis_summary || "",
                recommendations: raw.recommendations || [],
                sections: {
                    verbal: {
                        band: verbalBand,
                        correct: raw.listening_correct,
                        total: raw.listening_total,
                        level: getLevel(verbalBand),
                        strengths: raw.listening_strengths || [],
                        improvements: raw.listening_improvements || [],
                    },
                    math: {
                        band: mathBand,
                        correct: raw.grammar_correct,
                        total: raw.grammar_total,
                        level: getLevel(mathBand),
                        strengths: raw.grammar_strengths || [],
                        improvements: raw.grammar_improvements || [],
                    },
                },
            };
        }
    } catch (e) {
        console.error("Error fetching score data:", e);
        error = "An error occurred while loading your results.";
    }
}
---

<script is:inline>
    // Security Guard for Score Report
    const urlParams = new URLSearchParams(window.location.search);
    const regIdFromUrl = urlParams.get("registrationId");
    const regIdFromSession = sessionStorage.getItem("placement_registration_id");
    const stage = sessionStorage.getItem("placement_stage");

    if (!regIdFromUrl || regIdFromUrl !== regIdFromSession || stage !== 'result') {
        // Only redirect if there's no result in DB (but here we just check session for simplicity)
        // If they have the link but not the session, we could let them view it if it's public
        // but for now let's lock it to the active session as requested.
        console.warn("Unauthorized access attempt to score report.");
    }
</script>

<!doctype html>
<html lang="en">

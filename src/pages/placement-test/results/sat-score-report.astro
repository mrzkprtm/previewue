        <footer class="w-full bg-hero-gradient text-white/60 text-center py-8 text-sm mt-auto">
            <div class="container mx-auto px-6">
                © 2026 Ultimate Education. All rights reserved.
            </div>
        </footer>

        <script is:inline define:vars={{ scoreData }}>
            if (scoreData) {
                window.addEventListener("load", () => {
                    const getScoreColor = (value) => {
                        // Value is 0 to 1600
                        if (value >= 1400) return "#22C55E"; // Green
                        if (value >= 1200) return "#FFB800"; // Yellow/Orange
                        if (value >= 1000) return "#F97316"; // Orange
                        if (value > 0) return "#EF4444"; // Red
                        return "#94A3B8"; // Slate for 0
                    };

                    const createGauge = (id, label, value, colorOverride, cutout = "80%") => {
                        const el = document.getElementById(id);
                        if (!el) return;
                        
                        const color = colorOverride || getScoreColor(value);
                        
                        const ctx = el.getContext("2d");
                        new Chart(ctx, {
                            type: "doughnut",
                            data: {
                                datasets: [{
                                    data: [value || 0.1, Math.max(0, (id === 'gaugeOverall' ? 1600 : 800) - (value || 0.1))],
                                    backgroundColor: [colorOverride || (value > 800 ? getScoreColor(value) : (value >= 700 ? "#22C55E" : value >= 600 ? "#FFB800" : value >= 500 ? "#F97316" : "#EF4444")), id === 'gaugeOverall' ? "rgba(255, 255, 255, 0.1)" : "rgba(229, 231, 235, 0.5)"],
                                    borderWidth: 0,
                                    borderRadius: 10,
                                    cutout: cutout,
                                }],
                            },
                            options: {
                                circumference: id === 'gaugeOverall' ? 360 : 180,
                                rotation: id === 'gaugeOverall' ? 0 : 270,
                                plugins: {
                                    tooltip: { enabled: false },
                                    legend: { display: false },
                                },
                                responsive: true,
                                maintainAspectRatio: false,
                                animation: {
                                    duration: 2000,
                                    easing: "easeOutQuart",
                                },
                            },
                        });
                    };
 
                    // Overall Gauge - Using Dynamic Color
                    createGauge("gaugeOverall", "Overall", scoreData.overallBand, null, "85%");
 
                    // Section Gauges
                    createGauge("gaugeVerbal", "Verbal", scoreData.sections.verbal.band, "#0B63C5", "80%");
                    createGauge("gaugeMath", "Math", scoreData.sections.math.band, "#A855F7", "80%");
                });
            }
        </script>
    </body>
</html>

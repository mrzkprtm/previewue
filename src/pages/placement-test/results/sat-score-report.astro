                                const avg = id === 'verbal' ? 550 : 540;
                                const color = id === 'verbal' ? '#0B63C5' : '#A855F7';
                                return (
                                    <div class="relative pt-1">
                                        <div class="flex mb-2 items-center justify-between">
                                            <span class="text-xs font-bold uppercase tracking-wider text-slate-500">{id}</span>
                                            <div class="text-right text-xs font-bold text-slate-900">
                                                You ({data.band}) vs Avg ({avg})
                                            </div>
                                        </div>
                                        <div class="overflow-hidden h-2.5 mb-4 text-xs flex rounded bg-slate-100 relative">
                                            <div class="absolute top-0 bottom-0 w-0.5 bg-slate-400 z-10" style={`left: ${(avg/800)*100}%`}></div>
                                            <div class="shadow-none flex flex-col text-center whitespace-nowrap justify-center" style={`width: ${(data.band/800)*100}%; background-color: ${color}`}></div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </div>

                    <!-- Recommended Modules Card -->
                    <div class="bg-hero-gradient text-white p-8 rounded-2xl shadow-xl relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full -mr-16 -mt-16 pointer-events-none"></div>
                        <h3 class="text-lg font-bold text-white mb-6 relative z-10">
                            Rekomendasi
                        </h3>
                        <div class="space-y-4 relative z-10">
                            {scoreData.recommendations && scoreData.recommendations.length > 0 ? (

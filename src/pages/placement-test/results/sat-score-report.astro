                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/program/sat" class="bg-ultimate-yellow text-ultimate-navy font-bold px-8 py-4 rounded-full hover:bg-yellow-400 transition-all shadow-lg flex items-center justify-center gap-2 transform hover:scale-105">
                                <span class="material-symbols-outlined">description</span>
                                Daftar Persiapan SAT
                            </a>

---

---

<section
    class="relative pb-16 lg:pb-0 bg-hero-gradient overflow-hidden lg:min-h-[450px] lg:flex lg:items-center"
>
    <!-- Decorative element -->
    <!-- Hero Decoration (Image & Semi-circle) -->
    <div class="absolute inset-0 hidden lg:flex pointer-events-none z-10">
        <div class="container mx-auto w-full flex items-end justify-end">
            <div
                class="relative w-[35%] h-full flex flex-col items-center justify-end"
            >
                <!-- Semi-circle background -->
                <div
                    class="absolute top-0 w-[360px] h-[180px] bg-ultimate-yellow rounded-b-full left-1/3 -translate-y-[54px] z-0"
                >
                </div>
                <!-- Hero Image Overlay -->
                <!-- Using a relevant image for study abroad / test -->
                <img
                    src="/images/hero_img.png"
                    alt="Ilustrasi Placement Test"
                    class="absolute z-10 h-[85%] w-auto object-contain object-bottom left-[73%] -translate-x-1/2"
                />
            </div>
        </div>
    </div>

    <!-- Background Patterns -->

    <div class="w-full relative z-20 text-left">
        <div class="container mx-auto pt-12 lg:pt-8">
            <div class="lg:w-1/2 max-w-2xl">
                <div
                    class="inline-block px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-ultimate-yellow text-xs md:text-sm font-semibold mb-4 animate-float"
                >
                    Free Placement Test
                </div>
                <h1
                    class="font-heading font-semibold text-white text-3xl md:text-4xl lg:text-5xl mb-4 leading-snug"
                >
                    Mau <span class="text-ultimate-yellow">Study Abroad?</span
                    ><br />
                    Cek English Skill Kamu Lewat <br />
                    <span class="text-ultimate-yellow"
                        >FREE Placement Test!</span
                    >
                </h1>
                <p
                    class="text-slate-300 text-[15px] md:text-base lg:text-lg mb-8 leading-relaxed font-light"
                >
                    Ambil <span class="font-bold"
                        >Placement Test SAT & IELTS GRATIS</span
                    > biar tahu level, strategi & plan belajar terbaik buatmu!
                </p>
                <div class="flex">
                    <a
                        href="#test-selection"
                        class="bg-ultimate-yellow text-ultimate-navy font-bold py-3.5 px-8 rounded-full shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 transform font-heading inline-flex items-center justify-center"
                    >
                        Mulai Tes Gratis
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

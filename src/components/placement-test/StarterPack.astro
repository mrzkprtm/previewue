---

<!-- Starter Pack Section -->
<section class="py-12 bg-white">
    <div class="container mx-auto px-4">
        <div
            class="bg-ue-blue-light rounded-3xl p-8 border border-ue-blue-light shadow-sm"
        >
            <h3
                class="text-center text-2xl font-bold text-ultimate-navy mb-8 font-heading"
            >
                <span class="text-ultimate-blue">Starter Pack</span> yang harus kamu
                siapin!
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div
                    class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-sm"
                >
                    <div
                        class="w-12 h-12 flex-shrink-0 bg-ue-blue-light rounded-full flex items-center justify-center text-ultimate-blue"
                    >
                        <span class="material-icons text-2xl">schedule</span>
                    </div>
                    <p class="text-sm text-slate-700 font-body">
                        Alokasi <span class="font-bold">waktu 15-20 menit</span>
                    </p>
                </div>
                <div
                    class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-sm"
                >
                    <div
                        class="w-12 h-12 flex-shrink-0 bg-ue-blue-light rounded-full flex items-center justify-center text-ultimate-blue"
                    >
                        <span class="material-icons text-2xl">wifi</span>
                    </div>
                    <p class="text-sm text-ultimate-navy/80 font-body">
                        Jaringan internet <span class="font-bold"
                            >yang memadai</span
                        >
                    </p>
                </div>
                <div
                    class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-sm"
                >
                    <div
                        class="w-12 h-12 flex-shrink-0 bg-ue-blue-light rounded-full flex items-center justify-center text-ultimate-blue"
                    >
                        <span class="material-icons text-2xl">meeting_room</span
                        >
                    </div>
                    <p class="text-sm text-slate-700 font-body">
                        Ruangan yang <span class="font-bold"
                            >minim distraksi</span
                        >
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

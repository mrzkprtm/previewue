---

---

<!-- Test Selection Section -->
<section
    id="test-selection"
    class="py-16 bg-ue-blue-light relative overflow-hidden"
>
    <div class="container mx-auto px-4 relative z-10">
        <div class="text-center mb-12">
            <h2
                class="text-3xl font-bold text-ultimate-navy flex items-center justify-center gap-2 font-heading"
            >
                Let's Go Mulai <span class="text-ultimate-blue"
                    >Placement Test</span
                > Sekarang!
            </h2>
        </div>
        <div
            class="flex flex-col md:flex-row justify-center gap-8 max-w-5xl mx-auto"
        >
            <!-- IELTS Card -->
            <div
                class="w-full md:w-1/2 bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition duration-300 border border-slate-100 flex flex-col"
            >
                <div class="h-56 overflow-hidden bg-ue-blue-light/30">
                    <img
                        src="/program/ielts.png"
                        alt="IELTS"
                        class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-700"
                    />
                </div>
                <div
                    class="p-6 border-t-4 border-ultimate-blue flex-1 flex flex-col"
                >
                    <div class="flex justify-between items-start mb-4">
                        <span
                            class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded uppercase"
                            >Free</span
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-ultimate-navy mb-2 font-heading"
                    >
                        IELTS Placement Test
                    </h3>
                    <p class="text-sm text-slate-500 mb-6 font-body font-light">
                        Cocok untuk kamu yang basic English masih kurang tapi
                        punya plan belajar & ambil tes IELTS
                    </p>
                    <div class="space-y-3 mb-8 mt-auto">
                        <div
                            class="flex items-center gap-3 text-sm text-slate-600"
                        >
                            <span
                                class="material-icons text-ultimate-blue/40 text-base"
                                >quiz</span
                            >
                            <span class="font-body"
                                >Jumlah Soal <span
                                    class="font-bold text-ultimate-blue"
                                    >39</span
                                ></span
                            >
                        </div>
                        <div
                            class="flex items-center gap-3 text-sm text-slate-600"
                        >
                            <span
                                class="material-icons text-ultimate-blue/40 text-base"
                                >timer</span
                            >
                            <span class="font-body"
                                >Waktu Pengerjaan <span
                                    class="font-bold text-ultimate-blue"
                                    >35 Menit</span
                                ></span
                            >
                        </div>
                    </div>
                    <button
                        onclick="window.openRegistrationModal('IELTS')"
                        class="w-full bg-gradient-to-r from-ultimate-blue to-primary hover:brightness-110 text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition-all font-heading active:scale-95 shadow-lg shadow-blue-200"
                    >
                        <span class="material-icons text-lg">play_arrow</span> Mulai
                        Tes Gratis
                    </button>
                </div>
            </div>
            <!-- SAT Card -->
            <div
                class="w-full md:w-1/2 bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition duration-300 border border-slate-100 flex flex-col"
            >
                <div class="h-56 overflow-hidden bg-ue-blue-light/30">
                    <img
                        src="/program/sat.png"
                        alt="SAT"
                        class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-700"
                    />
                </div>
                <div
                    class="p-6 border-t-4 border-ultimate-blue flex-1 flex flex-col"
                >
                    <div class="flex justify-between items-start mb-4">
                        <span
                            class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded uppercase"
                            >Free</span
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-ultimate-navy mb-2 font-heading"
                    >
                        SAT Placement Test
                    </h3>
                    <p class="text-sm text-slate-500 mb-6 font-body font-light">
                        Cocok untuk kamu yang basic English & Math masih kurang
                        tapi punya plan belajar & ambil tes SAT
                    </p>
                    <div class="space-y-3 mb-8 mt-auto">
                        <div
                            class="flex items-center gap-3 text-sm text-slate-600"
                        >
                            <span
                                class="material-icons text-ultimate-blue/40 text-base"
                                >quiz</span
                            >
                            <span class="font-body"
                                >Jumlah Soal <span
                                    class="font-bold text-ultimate-blue"
                                    >27</span
                                ></span
                            >
                        </div>
                        <div
                            class="flex items-center gap-3 text-sm text-slate-600"
                        >
                            <span
                                class="material-icons text-ultimate-blue/40 text-base"
                                >timer</span
                            >
                            <span class="font-body"
                                >Waktu Pengerjaan <span
                                    class="font-bold text-ultimate-blue"
                                    >30 Menit</span
                                ></span
                            >
                        </div>
                    </div>
                    <button
                        onclick="window.openRegistrationModal('SAT')"
                        class="w-full bg-gradient-to-r from-ultimate-blue to-primary hover:brightness-110 text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition-all font-heading active:scale-95 shadow-lg shadow-blue-200"
                    >
                        <span class="material-icons text-lg">play_arrow</span> Mulai
                        Tes Gratis
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

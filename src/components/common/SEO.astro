---
import { SEO as AstroSEO } from "astro-seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  nofollow?: boolean;
  ogType?: "website" | "article" | "profile" | "book" | "video.other" | "video.movie" | "video.episode" | "video.tv_show" | "music.song" | "music.album" | "music.playlist" | "music.radio_station";
}

const {
  title,
  description = "Konsultan pendidikan luar negeri dan pusat persiapan tes IELTS, SAT, GRE, GMAT terpercaya di Indonesia.",
  image = "https://placehold.co/1200x630?text=Ultimate+Education",
  noindex = false,
  nofollow = false,
  ogType = "website",
} = Astro.props;

const canonicalURL = Astro.url.href;
---

<AstroSEO
  title={title}
  description={description}
  canonical={canonicalURL}
  noindex={noindex}
  nofollow={nofollow}
  openGraph={{
    basic: {
      title,
      type: ogType,
      image,
      url: canonicalURL,
    },
    optional: {
      description,
      siteName: "Ultimate Education",
      locale: "id_ID",
    },
  }}
  twitter={{
    card: "summary_large_image",
    site: "@Ultimate_Eduind",
    title,
    image,
    description,
  }}
  extend={{
    meta: [
      {
        name: "keywords",
        content: "Kursus IELTS Jakarta, Kursus GMAT Indonesia, Kursus GRE Bandung, Kursus SAT Jakarta, Bimbingan Belajar Luar Negeri, Ultimate Education, Persiapan beasiswa luar negeri, Konsultasi kuliah luar negeri",
      },
      { name: "viewport", content: "width=device-width, initial-scale=1" },
      { name: "generator", content: Astro.generator },
      { name: "theme-color", content: "#145da0" },
    ],
    link: [
      { rel: "icon", href: "/logos/favicon-32x32.png", type: "image/png" },
      { rel: "apple-touch-icon", href: "/logos/apple-touch-icon.png" },
      { rel: "sitemap", href: "/sitemap.xml" },
    ],
  }}
/>

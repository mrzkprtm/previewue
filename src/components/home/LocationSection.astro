              class="w-full inline-flex items-center justify-center gap-2 bg-white border-2 border-ultimate-navy text-ultimate-navy font-bold py-3 rounded-xl hover:bg-ultimate-navy hover:text-white transition-all duration-300 group/btn mt-auto"
            >

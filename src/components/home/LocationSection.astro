<section class="py-8 bg-slate-50 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#145da0 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="container mx-auto relative z-10">
    <div class="text-center mb-6 max-w-3xl mx-auto">
      <span class="inline-block py-1 px-3 rounded-full bg-ultimate-blue/10 border border-ultimate-blue/20 text-ultimate-blue text-sm font-semibold uppercase tracking-wider mb-4">Lokasi Kami</span>
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-ultimate-navy mb-6">Kunjungi Kantor Ultimate Education</h2>
      <p class="text-slate-600 text-lg leading-relaxed">Kami melayani konsultasi tatap muka di Jakarta dan Bandung, serta layanan online interaktif yang dapat diakses dari seluruh Indonesia.</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Jakarta -->
      <div class="bg-white rounded-3xl p-4 shadow-xl border border-slate-100 flex flex-col h-full hover:-translate-y-2 transition-transform duration-300 group relative overflow-hidden">
        <!-- Accent Line -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-ultimate-blue to-ultimate-navy"></div>

        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center text-ultimate-blue group-hover:bg-ultimate-blue group-hover:text-white transition-colors duration-300">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg
            >
          </div>
          <div>
            <h3 class="text-2xl font-bold font-heading text-ultimate-navy">Jakarta Selatan</h3>
            <p class="text-slate-500 text-sm font-medium">Head Office</p>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-[1fr_220px] md:items-stretch">
          <div class="flex flex-col">
            <div class="space-y-3 mb-4">
              <div class="flex gap-4">
                <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-3.5 h-3.5 text-ultimate-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                    ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                  >
                </div>
                <div class="text-slate-600 leading-relaxed">
                  <strong class="text-ultimate-navy block mb-1">Sampoerna Strategic Square</strong>
                  Jl. Jenderal Sudirman No. 45–46<br />
                  Jakarta Selatan, DKI Jakarta 12930
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0 mt-1">

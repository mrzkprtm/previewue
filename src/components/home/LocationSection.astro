              <svg class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
              >
            </a>
          </div>

          <div class="w-full h-28 md:h-[152px] bg-slate-100 rounded-2xl overflow-hidden relative shadow-inner border border-slate-200">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.982292723784!2d107.6114!3d-6.8927!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwNTMnMzMuNyJTIDEwN8KwMzYnNDEuMCJF!5e0!3m2!1sen!2sid!4v1709628000000!5m2!1sen!2sid"

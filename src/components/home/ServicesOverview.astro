---
---

<section class="py-16 bg-white relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-1/2 bg-slate-50/50 -skew-y-3 origin-top-left -z-10"></div>
  
  <div class="container mx-auto px-4">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <span class="inline-block py-1 px-3 rounded-full bg-ultimate-blue/10 border border-ultimate-blue/20 text-ultimate-blue text-sm font-semibold uppercase tracking-wider mb-4">Layanan Kami</span>
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-ultimate-navy mb-6">Solusi Lengkap untuk Studi Luar Negeri</h2>
      <p class="text-slate-600 text-lg">Kami menyediakan bimbingan komprehensif mulai dari persiapan tes bahasa, pemilihan universitas, hingga strategi beasiswa.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Service 1: Test Prep -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
        <div class="w-14 h-14 rounded-xl bg-blue-50 text-ultimate-blue flex items-center justify-center mb-6 group-hover:bg-ultimate-blue group-hover:text-white transition-colors">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-xl text-ultimate-navy mb-3">Persiapan Tes Internasional</h3>
        <p class="text-slate-500 text-sm mb-6 leading-relaxed">Bimbingan intensif untuk IELTS, SAT, GMAT, GRE, dan TOEFL dengan materi terupdate dan strategi skor tinggi.</p>
        <a href="/program" class="inline-flex items-center text-ultimate-blue font-semibold text-sm hover:underline">
          Lihat Program Tes
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>

      <!-- Service 2: Study Abroad -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
        <div class="w-14 h-14 rounded-xl bg-yellow-50 text-yellow-600 flex items-center justify-center mb-6 group-hover:bg-ultimate-yellow group-hover:text-ultimate-navy transition-colors">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-xl text-ultimate-navy mb-3">Konsultan Kuliah Luar Negeri</h3>
        <p class="text-slate-500 text-sm mb-6 leading-relaxed">Pendampingan pendaftaran universitas (Admission) untuk jenjang S1, S2, dan S3 di berbagai negara favorit.</p>
        <a href="/kontak" class="inline-flex items-center text-ultimate-blue font-semibold text-sm hover:underline">
          Konsultasi Gratis
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>

      <!-- Service 3: Language Courses -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
        <div class="w-14 h-14 rounded-xl bg-green-50 text-green-600 flex items-center justify-center mb-6 group-hover:bg-green-500 group-hover:text-white transition-colors">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-xl text-ultimate-navy mb-3">Kursus Bahasa Asing</h3>
        <p class="text-slate-500 text-sm mb-6 leading-relaxed">Kelas General & Business English, serta bahasa asing lainnya (Jerman, Mandarin, Korea, Jepang).</p>
        <a href="/program" class="inline-flex items-center text-ultimate-blue font-semibold text-sm hover:underline">
          Pilih Bahasa
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>

      <!-- Service 4: Scholarship Guidance -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
        <div class="w-14 h-14 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center mb-6 group-hover:bg-purple-500 group-hover:text-white transition-colors">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-xl text-ultimate-navy mb-3">Bimbingan Beasiswa</h3>
        <p class="text-slate-500 text-sm mb-6 leading-relaxed">Mentoring essay, interview, dan seleksi administratif untuk beasiswa LPDP, Chevening, AAS, dan lainnya.</p>
        <a href="/program/scholarship" class="inline-flex items-center text-ultimate-blue font-semibold text-sm hover:underline">
          Info Beasiswa
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </div>
  </div>
</section>
